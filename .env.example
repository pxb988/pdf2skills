# pdf2skills Configuration
# Most settings have sensible defaults. Only configure what you need to override.

# PDF Parser: "claude" (default, zero config) | "mineru" (needs API key) | "pypdf2" (local fallback)
# PDF_PARSER=claude

# MinerU API (only needed if PDF_PARSER=mineru)
# MINERU_API_KEY=your_mineru_api_key
# MINERU_BASE_URL=https://mineru.net/api/v4/extract/task

# Pipeline Parameters
# CHUNK_MAX_TOKENS=30000
# CHUNK_MAX_ITERATIONS=3
# DENSITY_CALIBRATION_SAMPLES=15
# BUCKET_THRESHOLD=0.5
# OUTPUT_LANGUAGE=English
# MAX_SKILL_LINES=500
# MAX_SKUS_PER_BATCH=15
