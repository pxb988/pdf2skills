# pdf2skills Configuration
# Copy this file to .pdf2skills/.env (project-level) or ~/.pdf2skills/.env (user-level).
#
# Priority (highest wins):
#   1. Shell environment variables / CLI exports
#   2. <cwd>/.pdf2skills/.env   (project-level)
#   3. ~/.pdf2skills/.env        (user-level)

# ─── PDF Parser ───────────────────────────────────────────────────────
# "auto" (default) | "claude" | "mineru" | "llm" | "pypdf2"
# auto = mineru (if key set) > llm (if provider active) > claude
# PDF_PARSER=auto

# ─── LLM Provider ────────────────────────────────────────────────────
# Which provider to use for LLM-based tasks (e.g. PDF→Markdown).
# Values: openai | anthropic | google | deepseek | zhipu | qwen | siliconflow | custom
# LLM_PROVIDER=

# ── US Providers ──────────────────────────────────────────────────────

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google (Gemini)
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-2.0-flash
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── China Providers ───────────────────────────────────────────────────

# DeepSeek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 智谱 GLM (Zhipu)
# ZHIPU_API_KEY=...
# ZHIPU_MODEL=glm-4-plus
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 通义千问 Qwen (DashScope)
# QWEN_API_KEY=sk-...
# QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# SiliconFlow
# SILICONFLOW_API_KEY=sk-...
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ── Custom (OpenAI-compatible) ────────────────────────────────────────
# CUSTOM_API_KEY=sk-...
# CUSTOM_MODEL=your-model-name
# CUSTOM_BASE_URL=https://your-api.example.com/v1

# ─── MinerU (dedicated PDF parser, optional) ─────────────────────────
# MINERU_API_KEY=...
# MINERU_BASE_URL=https://mineru.net/api/v4/extract/task

# ─── Pipeline Parameters ─────────────────────────────────────────────
# CHUNK_MAX_TOKENS=30000
# CHUNK_MAX_ITERATIONS=3
# DENSITY_CALIBRATION_SAMPLES=15
# BUCKET_THRESHOLD=0.5
# OUTPUT_LANGUAGE=English
# MAX_SKILL_LINES=500
# MAX_SKUS_PER_BATCH=15
